# Vero Salon — environment template.
# Copy to `.env` (or `.env.local`) and fill in real values. Never commit the filled-in file.

# --- Supabase (required) ---
# Supabase → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# 🔐 Bypasses RLS — server-only, never exposed to the browser. Keep secret.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Email (optional) ---
# Resend dashboard. If unset, booking still succeeds — email just no-ops.
RESEND_API_KEY=
# Must be a verified Resend sender.
RESEND_FROM_EMAIL="Vero Salon <bookings@yourdomain.com>"

# --- Site (required) ---
# http://localhost:3000 in dev; your production domain in prod.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Supabase CLI tooling (only for migrations / type generation) ---
# Supabase → Settings → Database → password. Used by `supabase db push`.
SUPABASE_DB_PASSWORD=
# Supabase access token, for `supabase gen types` without Docker.
SUPABASE_ACCESS_TOKEN=
