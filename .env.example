# ─────────────────────────────────────────────────────────────
# Vero Salon — environment template
# ─────────────────────────────────────────────────────────────
# Copy to `.env` (or `.env.local`) and fill in real values.
# NEVER commit the filled-in file. Vars prefixed NEXT_PUBLIC_ are exposed to the
# browser; everything else is server-only. See src/lib/env.ts for how these load.


# ── Supabase (required) ──────────────────────────────────────
# Supabase dashboard → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# 🔐 Bypasses RLS — server-only, never exposed to the browser. Keep secret.
# Used by the booking Server Action and the admin client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key


# ── Site (required) ──────────────────────────────────────────
# http://localhost:3000 in dev; your production domain in prod.
# Used for OAuth redirects and absolute links in emails.
NEXT_PUBLIC_SITE_URL=http://localhost:3000


# ── Email (optional) ─────────────────────────────────────────
# Resend dashboard → API Keys. If unset, bookings still succeed —
# confirmation email just no-ops.
RESEND_API_KEY=
# Must be a verified Resend sender. Falls back to Resend's onboarding sender
# (Vero Salon <onboarding@resend.dev>) when unset.
RESEND_FROM_EMAIL="Vero Salon <bookings@yourdomain.com>"


# ── Sri Lankan holidays (optional) ───────────────────────────
# Marks & blocks SL public + poya holidays on the booking calendar.
# Google Cloud Console → enable "Google Calendar API" → Credentials →
# Create API key. Application restriction MUST be "None" (or IP addresses) —
# the key is used server-side, so a "Websites" (referer) restriction blocks it.
# If unset, the calendar still works — no dates get blocked as holidays.
# Only used when an admin runs Admin → Holidays → Sync; the public calendar
# reads holidays from the `holidays` DB table, never Google directly.
GOOGLE_CALENDAR_API_KEY=


# ── Supabase CLI tooling (local only) ────────────────────────
# Only needed for `supabase db push` (migrations) and `supabase gen types`.
# Not read by the app at runtime.
# Supabase → Settings → Database → password.
SUPABASE_DB_PASSWORD=
# Supabase access token, for `supabase gen types` without Docker.
SUPABASE_ACCESS_TOKEN=
